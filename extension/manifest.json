{
  "manifest_version": 3,
  "name": "ColdMail AI - 外贸开发信助手",
  "version": "1.0.0",
  "description": "AI驱动的多语言外贸开发信生成器，支持6种语言，附带垃圾邮件检测和邮件评分",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
